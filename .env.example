# SMTP credentials for Oderland / Nesaku
SMTP_HOST=nesaku.oderland.com
SMTP_PORT=465
SMTP_SECURITY=ssl
SMTP_USERNAME=your-mailbox@example.com
SMTP_PASSWORD=replace-with-real-password
SMTP_TIMEOUT=30

# Sender details
MAIL_FROM=your-mailbox@example.com
MAIL_FROM_NAME=Ambition Sverige

# Local sender service
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# Optional default recipient when POST /send omits "to"
DEFAULT_TO=
